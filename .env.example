# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=tarkov_board
TZ=Asia/Shanghai

# App auth
APP_ADMIN_USERNAME=admin
# Required for production deploy. Set a bcrypt hash for the admin password.
# APP_ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# JWT
APP_JWT_SECRET=replace_with_a_strong_random_secret
APP_JWT_EXPIRESECONDS=7200

# Backend Docker image repository and tag
APP_IMAGE_REPOSITORY=luopc1218docker/tarkov-tactical-board-server
APP_IMAGE_TAG=latest

# Backend server listen port
SERVER_PORT=8080

# Optional context path for local development, empty by default
SERVER_SERVLET_CONTEXT_PATH=
