# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=tarkov_board
MYSQL_USER=tarkov
MYSQL_PASSWORD=change_me_db_password
TZ=Asia/Shanghai

# App auth
APP_ADMIN_USERNAME=admin
# Required for production deploy. Set a bcrypt hash for the admin password.
# APP_ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# JWT
APP_JWT_SECRET=replace_with_a_strong_random_secret
APP_JWT_EXPIRESECONDS=7200

# Public site domain used by Caddy for both frontend and backend
APP_DOMAIN=app.example.com

# Backend Docker image repository and tag
APP_IMAGE_REPOSITORY=luopc1218docker/tarkov-tactical-board-server
APP_IMAGE_TAG=latest

# Bind backend container to a local high port for host Nginx reverse proxy
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=18080

# Frontend Docker image repository and tag
FRONTEND_IMAGE_REPOSITORY=luopc1218docker/tarkov-tactical-board-frontend
FRONTEND_IMAGE_TAG=latest
